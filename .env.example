# Zmienne środowiskowe — skopiuj do panelu Vercel (Settings → Environment Variables).
# NIE commituj prawdziwych wartości do repo.

# Klucz API z https://resend.com (Dashboard → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Adres, na który mają trafiać zgłoszenia z formularzy
MAIL_TO=office@sharedhotels.com

# Adres nadawcy — MUSI być na domenie zweryfikowanej w Resend
MAIL_FROM=Shared Hotels <no-reply@sharedhotels.com>
