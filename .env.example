# Zmienne środowiskowe — skopiuj do panelu Vercel (Settings → Environment Variables).
# NIE commituj prawdziwych wartości do repo.

# --- SMTP OVH (wysyłka maili przez skrzynkę OVH) ---
# MX Plan:    ssl0.ovh.net
# Email Pro:  pro*.mail.ovh.net   (dokładny host w panelu OVH przy skrzynce)
# Exchange:   ex*.mail.ovh.net
SMTP_HOST=ssl0.ovh.net

# 465 = SSL/TLS (zalecane), 587 = STARTTLS
SMTP_PORT=465

# Pełny adres skrzynki nadawczej OVH
SMTP_USER=no-reply@sharedhotels.com

# Hasło tej skrzynki
SMTP_PASS=********

# Adres, na który mają trafiać zgłoszenia z formularzy
MAIL_TO=office@sharedhotels.com

# Nadawca — MUSI być równy SMTP_USER albo jego aliasowi
MAIL_FROM=Shared Hotels <no-reply@sharedhotels.com>
